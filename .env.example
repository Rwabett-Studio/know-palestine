# ─────────────────────────────────────────────────────────
# Public environment variables (safe to expose in client)
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Supabase — public anon key (safe for client)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Site base URL — used for canonical URLs, og:url, sitemap, structured data.
# No trailing slash. Required for correct SEO in production.
VITE_SITE_URL=https://knowpalestine.com

# ─────────────────────────────────────────────────────────
# Server-only environment variables (NEVER use VITE_ prefix)
# Set these in Cloudflare Worker secrets or .env (server-side only).
# ─────────────────────────────────────────────────────────

# Anthropic API key — for AI TEXT generation (articles, cities, figures, history)
ANTHROPIC_API_KEY=sk-ant-...

# Override the default Anthropic model (optional)
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI API key — for AI IMAGE generation (DALL-E 3) in admin editors
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
